rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Profiles Collection ---
    match /profiles/{userId} {
      allow get, write: if isOwner(userId) && isValidId(userId);
      
      // Validation for Profile
      function isValidProfile(data) {
        return data.keys().hasAll(['userId', 'email'])
          && data.userId == request.auth.uid
          && data.email is string;
      }

      allow create: if isOwner(userId) && isValidProfile(incoming());
      allow update: if isOwner(userId) && isValidProfile(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly([
                      'vehicleName', 'vehicleType', 'fuelType', 'avgConsumption', 
                      'fuelPrice', 'fixedCostsMonthly', 'maintenanceMonthly', 
                      'onboardingCompleted', 'isPremium'
                    ]);
    }

    // --- Entries Subcollection ---
    match /profiles/{userId}/entries/{entryId} {
      allow list, get, delete: if isOwner(userId);
      
      function isValidEntry(data) {
        return data.keys().hasAll(['date', 'grossRevenue', 'totalKm'])
          && data.grossRevenue is number
          && data.totalKm is number
          && data.date is timestamp;
      }

      allow create: if isOwner(userId) && isValidEntry(incoming());
      allow update: if isOwner(userId) && isValidEntry(incoming());
    }
  }
}
